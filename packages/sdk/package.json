{
  "name": "@spanlens/sdk",
  "version": "0.9.0",
  "description": "Spanlens SDK — agent tracing, LLM usage capture, and cost observability for TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openai": {
      "import": "./dist/integrations/openai.js",
      "types": "./dist/integrations/openai.d.ts"
    },
    "./anthropic": {
      "import": "./dist/integrations/anthropic.js",
      "types": "./dist/integrations/anthropic.d.ts"
    },
    "./gemini": {
      "import": "./dist/integrations/gemini.js",
      "types": "./dist/integrations/gemini.d.ts"
    },
    "./langchain": {
      "import": "./dist/integrations/langchain.js",
      "types": "./dist/integrations/langchain.d.ts"
    },
    "./vercel-ai": {
      "import": "./dist/integrations/vercel-ai.js",
      "types": "./dist/integrations/vercel-ai.d.ts"
    },
    "./llamaindex": {
      "import": "./dist/integrations/llamaindex.js",
      "types": "./dist/integrations/llamaindex.d.ts"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.24.0",
    "@google/generative-ai": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true },
    "@google/generative-ai": { "optional": true }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@google/generative-ai": "^0.24.1",
    "@types/node": "^25.8.0",
    "openai": "^6.42.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "llm",
    "llm-observability",
    "llm-monitoring",
    "llm-tracing",
    "openai",
    "openai-sdk",
    "anthropic",
    "claude",
    "gemini",
    "google-generative-ai",
    "observability",
    "observability-sdk",
    "tracing",
    "agent-tracing",
    "ai-agents",
    "cost-tracking",
    "token-tracking",
    "langchain",
    "llamaindex",
    "vercel-ai",
    "ai-sdk",
    "ollama",
    "next.js",
    "nextjs",
    "typescript",
    "helicone-alternative",
    "langfuse-alternative",
    "langsmith-alternative",
    "proxy",
    "baseurl",
    "spanlens"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spanlens/Spanlens.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/spanlens/Spanlens/issues"
  },
  "homepage": "https://spanlens.io",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
