{
  "version": 2,
  "framework": null,
  "outputDirectory": null,
  "installCommand": "npm install",
  "regions": ["icn1"],
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "crons": [
    { "path": "/cron/evaluate-alerts",      "schedule": "*/15 * * * *" },
    { "path": "/cron/snapshot-anomalies",   "schedule": "0 1 * * *" },
    { "path": "/cron/stale-key-reminders",  "schedule": "0 9 * * 1" },
    { "path": "/cron/leak-detect-keys",          "schedule": "0 4 * * *" },
    { "path": "/cron/recommend-savings-alerts",  "schedule": "0 9 * * *" },
    { "path": "/cron/replay-fallback",            "schedule": "*/5 * * * *" },
    { "path": "/cron/check-past-due-downgrades",  "schedule": "0 10 * * *" },
    { "path": "/cron/execute-pending-deletions",  "schedule": "0 */6 * * *" },
    { "path": "/cron/keep-warm",                  "schedule": "*/5 * * * *" }
  ]
}
