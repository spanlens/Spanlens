# Server
PORT=3001

# Supabase (local: use values printed by `supabase start`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Encryption key: generate with `openssl rand -base64 32` (must be 32 bytes).
# If misconfigured, Provider Key decryption silently fails (returns empty string).
ENCRYPTION_KEY=<32-bytes-base64-encoded-key>

# Vercel cron auth — /cron/* endpoints verify this as a Bearer token.
# Store the same value under Vercel Dashboard → Environment Variables (Vercel injects automatically).
# Dev: generate with `openssl rand -hex 32`
CRON_SECRET=

# Resend (email notifications).
# If unset, invitation links are printed to console (local dev only).
RESEND_API_KEY=
# Base URL for invitation accept links. Production: https://www.spanlens.io
WEB_URL=http://localhost:3000

# GitGuardian HasMySecretLeaked (provider key leak detection — required only when leak_detection_enabled is on).
# Sign up: https://dashboard.gitguardian.com → Settings → API → Personal Access Tokens
# Free plan: 10,000 calls/month, 50 requests/minute.
# If unset, leak detection cron is a no-op.
GITGUARDIAN_API_KEY=

# Paddle (Merchant of Record, billing, Phase 2).
# Paddle instead of Stripe because Korean sole-proprietors can't onboard to Stripe + Paddle handles global VAT/tax automatically.
# API key: Paddle Dashboard → Developer Tools → Authentication → API Keys
# Notification secret: Paddle Dashboard → Developer Tools → Notifications → secret (webhook signature verification)
PADDLE_API_KEY=
PADDLE_NOTIFICATION_SECRET=
# 'sandbox' for Paddle Sandbox, 'production' for live billing.
PADDLE_ENVIRONMENT=sandbox

# Sentry — error monitoring (https://sentry.io).
# Create two projects: spanlens-server (Node) + spanlens-web (Next.js).
# Leave blank to disable Sentry (local dev default).
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=spanlens-server
SENTRY_AUTH_TOKEN=

# Upstash for Redis — rate limiting (sliding window).
# Auto-injected when connecting Vercel Storage → "upstash-kv-aqua-flask".
# Local dev: if unset, rate limit fails open (always allows).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ClickHouse — the `requests` table lives here (not Supabase).
# Local dev: `docker compose up clickhouse`, then use the defaults below.
# Production: sign up at ClickHouse Cloud (https://clickhouse.cloud/) and paste the issued values.
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=spanlens
CLICKHOUSE_PASSWORD=spanlens
CLICKHOUSE_DB=spanlens

# 4B.2 — Spanlens dogfoods itself. When both vars are set the
# eval-runner posts a `eval_run` trace to a dedicated "spanlens-team"
# workspace so we can see our own LLM-judge cost / latency / errors in
# /traces alongside customer data. Leave blank locally and in CI — the
# tracing helper degrades to no-op so nothing leaks to production.
#
# SPANLENS_INTERNAL_BASE_URL=https://server.spanlens.io
# SPANLENS_INTERNAL_API_KEY=sl_live_<hex>
SPANLENS_INTERNAL_BASE_URL=
SPANLENS_INTERNAL_API_KEY=
